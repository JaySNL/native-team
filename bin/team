#!/bin/sh
# `team` — the CLI a lead and its grunts both call.
#
# Resolves the package from its own location, so `bin/` can be symlinked into
# ~/.local/bin and a grunt in ANY repo can still run `team result add`. Nothing
# depends on PYTHONPATH being exported in the shell that launched the session:
# `team grunt add` puts this directory on the new pane's PATH with
# `tmux split-window -e`.
set -e
self=$(readlink -f "$0")
repo=$(dirname "$(dirname "$self")")
PYTHONPATH="$repo${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m team "$@"
