#!/bin/sh
# team-up [n-grunts] — compatibility shim.
#
# Pane creation now lives in `team up` (Python), so that one module owns tmux
# and the roster records pane IDs rather than indices, which renumber when a
# pane dies. This script exists so muscle memory and older docs keep working.
exec "$(dirname "$(readlink -f "$0")")/team" up "$@"
