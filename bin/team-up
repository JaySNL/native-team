#!/usr/bin/env bash
# team-up [n-grunts]  — build the tmux session and write roster.json.
#
# roster.json is written by the script that CREATES the panes, so it records
# what exists rather than guessing (papercut #9).
#
# Every value that ends up inside a string tmux later hands to `sh -c`
# (pipe-pane's log path, the pane-died hook's script path) goes through
# quote_path, which delegates to Python's shlex.quote -- the same mechanism
# team/panes.py already uses, where a missing shlex.quote was caught in
# review. Never build one of these strings by hand.
set -euo pipefail

GRUNTS="${1:-1}"
SESSION="${TEAM_SESSION:-team}"
ROOT="$(git rev-parse --show-toplevel)"
TEAM="$ROOT/.team"

[ -d "$TEAM" ] || { echo "no $TEAM — run 'team init' first" >&2; exit 3; }
tmux has-session -t "$SESSION" 2>/dev/null && { echo "session $SESSION exists" >&2; exit 3; }

quote_path() {
  python3 -c 'import shlex, sys; print(shlex.quote(sys.argv[1]))' "$1"
}

# Hook scripts live under a fresh mktemp dir, never under $TEAM. Verified
# live against tmux 3.7b: a hook fired by tmux hands run-shell's *stored*
# argument to `sh -c` unquoted -- a hook script path containing a space
# reliably fails (sh splits it into multiple words and the first word is not
# found) even though the identical single-quoted path works fine when `tmux
# run-shell` is invoked directly. mktemp sidesteps the hazard outright: its
# path is guaranteed free of spaces and shell metacharacters no matter where
# $ROOT lives. (These scripts are small and inert once the session ends;
# `team-up` does not clean them up, same as any other tmpdir.)
HOOKDIR="$(mktemp -d -t team-up-hooks.XXXXXX)"

# roster.json is machine data, so it is written by json.dump -- never piped
# through `python3 -m json.tool`. Python 3.14's json.tool honours FORCE_COLOR
# even when stdout is a file, so it emitted ANSI escapes into the JSON and
# every `team send` died with "unreadable bus file". Caught on the first real
# fan-out run, 2026-07-10.
#
# Written before the panes exist, because `team worktree up` reads it and the
# worktrees must exist before a pane can be opened inside one.
python3 - "$TEAM/roster.json" "$SESSION" "$GRUNTS" <<'PY'
import json, sys
path, session, n = sys.argv[1], sys.argv[2], int(sys.argv[3])
roster = {"lead": {"pane": f"{session}:0.0", "backend": "claude"}}
for i in range(1, n + 1):
    roster[f"grunt{i}"] = {"pane": f"{session}:0.{i}", "backend": "qwen"}
with open(path, "w", encoding="utf-8") as fh:
    json.dump(roster, fh, indent=2)
    fh.write("\n")
PY

# Give each grunt its private worktree, and its `.qwen/settings.json` inside it.
# A grunt pane's cwd IS its worktree: qwen resolves its project root from cwd,
# and its file tools take no cwd of their own -- a pane rooted in the main tree
# writes into the main tree, where containment cannot see it (measured, task
# 013). Non-fatal: without a worktree the pane falls back to $ROOT, `find` tasks
# still work, and `send --type build` refuses.
python3 -m team worktree up || \
  echo "warning: no grunt worktrees; build tasks will refuse. find tasks are unaffected." >&2

tmux new-session -d -s "$SESSION" -c "$ROOT" 'claude'
tmux pipe-pane -o -t "$SESSION:0.0" "cat >> $(quote_path "$TEAM/logs/lead.log")"

for i in $(seq 1 "$GRUNTS"); do
  name="grunt$i"
  cwd="$TEAM/work/$name"
  [ -d "$cwd" ] || cwd="$ROOT"
  tmux split-window -t "$SESSION:0" -c "$cwd" 'qwen'
  tmux select-layout -t "$SESSION:0" tiled
  pane="$SESSION:0.$i"
  tmux pipe-pane -o -t "$pane" "cat >> $(quote_path "$TEAM/logs/$name.log")"

  # pane-died hook (see docs/tmux-capabilities.md): reports a crashed grunt
  # to the lead's inbox the instant it dies, instead of waiting on `team
  # wait`'s timeout. Measured live on this machine's tmux (3.7b):
  #   remain-on-exit off (the default) -> the pane is destroyed immediately
  #     and `pane-exited` fires; `pane-died` never does.
  #   remain-on-exit on  -> the pane is kept, marked "(dead)", and
  #     `pane-died` fires.
  # `pane-died` + remain-on-exit=on is what we want here: the dead pane
  # stays visible in the layout (frozen on its last output) instead of
  # being silently reaped.
  tmux set-option -p -t "$pane" remain-on-exit on

  hookscript="$HOOKDIR/$name-died.sh"
  {
    printf '#!/bin/sh\n'
    printf 'export PYTHONPATH=%s\n' "$(quote_path "$ROOT")"
    printf 'exec python3 -m team --root %s msg --agent %s --failed --task pane-died %s\n' \
      "$(quote_path "$ROOT")" "$(quote_path "$name")" "$(quote_path "grunt pane died")"
  } > "$hookscript"
  chmod +x "$hookscript"
  tmux set-hook -p -t "$pane" pane-died "run-shell $(quote_path "$hookscript")"

done

BRIEF="$(python3 -m team brief 2>/dev/null || true)"

echo "session $SESSION up with $GRUNTS grunt(s). Attach: tmux attach -t $SESSION"
if [ -n "$BRIEF" ]; then
  # Deliberately not sent into the lead pane. Injecting keystrokes into a
  # claude REPL that may not have finished starting is a race, and the leading
  # Escape that `send_line` uses would cancel whatever it was doing. Paste it.
  echo
  echo "In the lead pane (pane 0), paste this once:"
  echo "    Read $BRIEF and follow it."
fi
